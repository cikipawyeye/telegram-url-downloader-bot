NODE_ENV=production
PORT=8000

# Required
BOT_TOKEN=replace_me
PUBLIC_BASE_URL=https://your-domain.example.com

# Random secret used to protect the webhook endpoint.
WEBHOOK_SECRET=replace_with_a_long_random_string

# Optional, but strongly recommended if you self-host Telegram Bot API locally
# Example: http://127.0.0.1:8081
TELEGRAM_API_ROOT=

# Temporary working directory inside the container/server
DOWNLOAD_DIR=/tmp/telegram-video-bot

# Max size accepted by the app before trying to send back to Telegram (bytes)
# 2147483648 = 2 GiB
MAX_FILE_SIZE_BYTES=2147483648

# Maximum runtime for one yt-dlp job in milliseconds
DOWNLOAD_TIMEOUT_MS=9000000

SCREENSHOT_COUNT=5